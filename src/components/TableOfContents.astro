---
import TableOfContentsHeading from "./TableOfContentsHeading.astro";

// https://kld.dev/building-table-of-contents/
const { headings } = Astro.props;
const toc = buildToc(headings);

export interface Heading {
  depth: number;
  slug: string;
  text: string;
}

function buildToc(headings: Heading[]) {
  const toc: any[] = [];
  const stack: any[] = [];
  headings.forEach((h) => {
    const heading = { ...h, subheadings: [] };
    // Nest under the nearest preceding heading of a shallower depth.
    // Robust to documents that start at any depth (h1/h3/…) or skip levels.
    while (stack.length > 0 && stack[stack.length - 1].depth >= heading.depth) {
      stack.pop();
    }
    if (stack.length === 0) {
      toc.push(heading);
    } else {
      stack[stack.length - 1].subheadings.push(heading);
    }
    stack.push(heading);
  });
  return toc;
}
---

<nav aria-label="目录" class="text-sm">
  <p
    class="mb-3 text-xs font-semibold tracking-widest text-black/45 dark:text-white/45"
  >
    目录
  </p>
  <ul class="space-y-0.5">
    {toc.map((heading) => <TableOfContentsHeading heading={heading} />)}
  </ul>
</nav>
