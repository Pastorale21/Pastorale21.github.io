---
// TeaSeal.astro — 首页左栏的「茶印」触发器：只负责印本身与其动效。
// 斟出的作品由 TeaPourBand.astro 渲染到右栏顶部的带子；二者通过
// #tea-seal / #tea-band 协作，控制脚本在 TeaPourBand.astro。
---
<svg width="0" height="0" style="position:absolute" aria-hidden="true" focusable="false">
  <filter id="ts-erode" x="-18%" y="-18%" width="136%" height="136%">
    <feTurbulence type="fractalNoise" baseFrequency="0.85" numOctaves="2" seed="7" result="n"/>
    <feDisplacementMap in="SourceGraphic" in2="n" scale="4" xChannelSelector="R" yChannelSelector="G"/>
  </filter>
  <filter id="ts-brush" x="-30%" y="-30%" width="160%" height="160%">
    <feTurbulence type="fractalNoise" baseFrequency="0.07 0.09" numOctaves="2" seed="4" result="w"/>
    <feDisplacementMap in="SourceGraphic" in2="w" scale="2.6"/>
  </filter>
</svg>

<div class="tea-seal" id="tea-seal" role="button" tabindex="0" aria-label="喫茶——斟一首作品">
  <svg viewBox="0 0 100 100" aria-hidden="true">
    <g filter="url(#ts-brush)" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
      <g class="steam" stroke-width="3.6">
        <path d="M40 29 C36 25 44 22 40 18 C38 16 42 16 42 15"/>
        <path d="M50 29 C46 24 55 20 50 14 C47 10 53 9 53 5"/>
        <path d="M60 29 C64 25 56 21 60 17 C62 14 60 12 61 10"/>
      </g>
      <path stroke-width="6" d="M31 37 34 73 41 73 41 79 59 79 59 73 67 73 70 37"/>
      <path stroke-width="4.5" d="M28 36C39 33 61 33 72 36 61 39 39 39 28 36Z"/>
    </g>
  </svg>
  <span class="ring"></span>
  <span class="ripple"></span>
  <span class="ripple ripple2"></span>
</div>
<div class="tea-seal-cap">喝一杯</div>

<style is:global>
  .tea-seal {
    width: 4rem;
    height: 4rem;
    border-radius: 22%;
    display: grid;
    place-items: center;
    position: relative;
    background: var(--color-seal, #b1462f);
    color: var(--surface-page, #f6f5f1);
    filter: url(#ts-erode);
    cursor: pointer;
    user-select: none;
    outline: none;
    -webkit-tap-highlight-color: transparent;
    transition: transform 0.25s cubic-bezier(0.2, 0.7, 0.3, 1.4);
  }
  .tea-seal:active { transform: scale(0.93); }
  .tea-seal:focus-visible { box-shadow: 0 0 0 3px color-mix(in oklab, var(--accent, #b1462f) 32%, transparent); }
  .tea-seal svg { display: block; width: 58%; height: 58%; }

  /* 点击引导：茶印下方一行安静的提示 */
  .tea-seal-cap {
    margin-top: 0.7rem;
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    color: var(--text-quiet, #6b6a64);
  }

  /* 待点击引导 · 暖意呼吸 + 袅袅热气（首次斟茶后 .started 停止） */
  .tea-seal:not(.started) { animation: tea-ember 3.6s ease-in-out infinite; }
  @keyframes tea-ember {
    0%, 100% { background: var(--color-seal, #b1462f); }
    50% { background: color-mix(in oklab, var(--color-seal, #b1462f) 72%, oklch(82% 0.13 50)); }
  }
  .tea-seal:not(.started) .steam path { animation: tea-idle-steam 3.2s ease-in-out infinite; }
  .tea-seal:not(.started) .steam path:nth-child(2) { animation-delay: 0.5s; }
  .tea-seal:not(.started) .steam path:nth-child(3) { animation-delay: 1s; }
  @keyframes tea-idle-steam {
    0% { stroke-dashoffset: 30; opacity: 0.25; }
    45% { opacity: 0.9; }
    90% { stroke-dashoffset: 0; opacity: 0.15; }
    100% { opacity: 0; }
  }

  /* 悬停 · 朱砂涟漪：印底向外一圈圈晕开（持续，鼠标移开即止）。
     用一组专属的 .ripple，与点击的一次性 .ring 涟漪互不干扰。 */
  .tea-seal .ripple {
    position: absolute;
    inset: -7px;
    border-radius: 24%;
    border: 1px solid var(--accent, #b1462f);
    opacity: 0;
    transform: scale(0.84);
    pointer-events: none;
  }
  .tea-seal:hover .ripple { animation: tea-hover-ripple 1.9s ease-out infinite; }
  .tea-seal:hover .ripple2 { animation-delay: 0.95s; }
  @keyframes tea-hover-ripple {
    0% { opacity: 0.5; transform: scale(0.84); }
    100% { opacity: 0; transform: scale(1.52); }
  }

  /* 落印手势：每次斟茶按一下并微侧（一次性） */
  .tea-seal.is-pour { animation: ts-stamp 0.34s cubic-bezier(0.3, 0.8, 0.3, 1); }
  @keyframes ts-stamp {
    0% { transform: scale(1) rotate(0); }
    38% { transform: scale(0.9) rotate(-2deg); }
    100% { transform: scale(1) rotate(0); }
  }

  .tea-seal .ring {
    position: absolute;
    inset: -8px;
    border-radius: 24%;
    border: 1px solid var(--accent, #b1462f);
    opacity: 0;
    transform: scale(0.8);
    pointer-events: none;
  }
  .tea-seal.is-pour .ring { animation: ts-ripple 0.7s ease-out; }
  @keyframes ts-ripple {
    0% { opacity: 0.5; transform: scale(0.85); }
    100% { opacity: 0; transform: scale(1.6); }
  }

  /* 蒸汽：三缕热气斟茶时依次升腾（一次性） */
  .tea-seal .steam path { stroke-dasharray: 30; stroke-dashoffset: 0; }
  .tea-seal.is-pour .steam path { animation: ts-steam 0.85s ease-out; }
  .tea-seal.is-pour .steam path:nth-child(2) { animation-delay: 0.08s; }
  .tea-seal.is-pour .steam path:nth-child(3) { animation-delay: 0.16s; }
  @keyframes ts-steam {
    from { stroke-dashoffset: 30; opacity: 0.15; }
    60% { opacity: 1; }
    to { stroke-dashoffset: 0; opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .tea-seal.is-pour,
    .tea-seal.is-pour .ring,
    .tea-seal.is-pour .steam path,
    .tea-seal:hover .ripple,
    .tea-seal:not(.started),
    .tea-seal:not(.started) .steam path { animation: none !important; }
  }
</style>
