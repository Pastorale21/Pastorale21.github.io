---
import type { CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import FormattedDate from "@components/FormattedDate.astro";
import { getFirstImage } from "@lib/utils";

type Props = {
  entry: CollectionEntry<"blog">;
  centered?: boolean;
  showCover?: boolean;
};

const { entry, centered = false, showCover = true } = Astro.props as {
  entry: CollectionEntry<"blog">;
  centered?: boolean;
  showCover?: boolean;
};

// Prefer an optimized, co-located cover from frontmatter; otherwise fall
// back to the first inline image URL (legacy posts pointing at /images/…).
// Callers (e.g. the tag listing) can suppress the cover entirely.
const cover = showCover ? entry.data.cover : undefined;
const coverUrl = !showCover || cover ? undefined : getFirstImage(entry.body ?? "");

// Two treatments: a centered, spacious "featured" feed (home page) and a
// compact left-aligned index (archive, tags). Hierarchy is carried by size +
// color + tracking, since the serif only renders at weights 400 / 700.
const rootClass = centered
  ? "not-prose group mx-auto block text-center"
  : "not-prose group block";
const dateClass = centered
  ? "text-xs tracking-wide text-black/75 dark:text-white/60"
  : "text-sm text-black/75 dark:text-white/60";
const titleClass = centered
  ? "mt-1.5 text-2xl leading-snug text-pretty text-black transition-colors duration-300 ease-in-out group-hover:text-[var(--accent)] group-focus-visible:text-[var(--accent)] dark:text-white"
  : "mt-1 text-lg text-balance text-black transition-colors duration-300 ease-in-out group-hover:text-[var(--accent)] group-focus-visible:text-[var(--accent)] dark:text-white";
const imgClass = centered
  ? "mx-auto mt-4 aspect-[3/2] w-full max-w-sm rounded-md border border-black/10 object-cover dark:border-white/10"
  : "mt-3 aspect-[3/2] w-full max-w-sm rounded-md border border-black/10 object-cover dark:border-white/10";
// The centered title now spans the home's full (wider) column so it sits on one
// line, but the excerpt stays held to a calm max-w-xl measure so multi-line
// Chinese doesn't ragged out across the wide column.
const descClass = centered
  ? "mx-auto mt-3 line-clamp-2 max-w-xl text-pretty text-sm text-black/80 dark:text-white/70"
  : "mt-3 line-clamp-2 text-pretty text-sm text-black/80 dark:text-white/70";
---

<a href={`/${entry.collection}/${entry.id}`} class={rootClass}>
  <div class={dateClass}>
    <FormattedDate date={entry.data.date} />
  </div>
  <h3 class={titleClass}>
    {entry.data.title}
  </h3>
  {
    cover ? (
      <Image
        src={cover}
        alt={entry.data.title}
        width={768}
        loading="lazy"
        class={imgClass}
      />
    ) : coverUrl ? (
      <img src={coverUrl} alt={entry.data.title} loading="lazy" class={imgClass} />
    ) : null
  }
  <p class={descClass}>
    {entry.data.description}
  </p>
</a>
