---
import type { CollectionEntry } from "astro:content";
import FormattedDate from "@components/FormattedDate.astro";
import { getFirstImage } from "@lib/utils";

type Props = {
  entry: CollectionEntry<"blog">;
  centered?: boolean;
};

const { entry, centered = false } = Astro.props as {
  entry: CollectionEntry<"blog">;
  centered?: boolean;
};

const cover = getFirstImage(entry.body ?? "");

// Two treatments: a centered, spacious "featured" feed (home page) and a
// compact left-aligned index (archive, tags). Hierarchy is carried by size +
// color + tracking, since the serif only renders at weights 400 / 700.
const rootClass = centered
  ? "not-prose group mx-auto block max-w-xl text-center"
  : "not-prose group block";
const dateClass = centered
  ? "text-xs tracking-wide text-black/45 dark:text-white/45"
  : "text-sm text-black/50 dark:text-white/50";
const titleClass = centered
  ? "mt-1.5 text-xl leading-snug text-black transition-colors duration-300 ease-in-out group-hover:text-[var(--accent)] group-focus-visible:text-[var(--accent)] dark:text-white"
  : "mt-1 text-lg text-black transition-colors duration-300 ease-in-out group-hover:text-[var(--accent)] group-focus-visible:text-[var(--accent)] dark:text-white";
const imgClass = centered
  ? "mx-auto mt-4 aspect-[3/2] w-full max-w-sm rounded-md border border-black/10 object-cover dark:border-white/10"
  : "mt-3 aspect-[3/2] w-full max-w-sm rounded-md border border-black/10 object-cover dark:border-white/10";
---

<a href={`/${entry.collection}/${entry.id}`} class={rootClass}>
  <div class={dateClass}>
    <FormattedDate date={entry.data.date} />
  </div>
  <h3 class={titleClass}>
    {entry.data.title}
  </h3>
  {
    cover && (
      <img src={cover} alt={entry.data.title} loading="lazy" class={imgClass} />
    )
  }
  <p class="mt-3 line-clamp-2 text-sm text-black/60 dark:text-white/60">
    {entry.data.description}
  </p>
</a>
