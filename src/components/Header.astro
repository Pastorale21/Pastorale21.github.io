---
import Link from "@components/Link.astro";
import { CATEGORIES, SITE } from "@consts";

// Underline-free nav links; hover/focus shifts to the terracotta accent so
// there's still clear feedback without the underline.
const navLink =
  "transition-colors duration-300 ease-in-out hover:text-[var(--accent)] focus-visible:text-[var(--accent)]";
---

<header transition:persist>
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <div class="flex flex-wrap items-center justify-between gap-y-2">
      <Link href="/" underline={false}>
        <div class="flex items-center gap-3 text-xl font-semibold tracking-[0.06em]">
          <img
            src="/logo.jpg"
            alt={SITE.TITLE}
            width="32"
            height="32"
            class="size-8 rounded-md"
          />
          {SITE.TITLE}
        </div>
      </Link>
      <nav class="flex flex-wrap items-center gap-x-4 gap-y-1 text-base tracking-[0.08em]">
        {CATEGORIES.map((category) => (
          <a href={category.HREF} class={navLink}>
            {category.LABEL}
          </a>
        ))}
        <span aria-hidden="true" class="h-3.5 w-px bg-black/15 dark:bg-white/20"></span>
        <a href="/blog" class={navLink}>文章</a>
        <a href="/tags" class={navLink}>标签</a>
      </nav>
    </div>
  </div>
</header>
