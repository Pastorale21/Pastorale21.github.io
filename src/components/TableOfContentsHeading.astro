---
import type { Heading } from "./TableOfContents.astro";

// https://kld.dev/building-table-of-contents/

const { heading, isRoot = false } = Astro.props;

// Level-based tone so the hierarchy reads at a glance (with the indent on
// nested lists). Every tier clears the Contrast Floor (≥ /75 in light mode).
const tone =
  heading.depth <= 1
    ? "text-black/90 dark:text-white/80"
    : heading.depth === 2
      ? "text-black/80 dark:text-white/70"
      : "text-black/75 dark:text-white/65";

const linkClass = [
  "block truncate py-1 transition-colors duration-200 ease-in-out hover:text-black dark:hover:text-white",
  tone,
];

// Top-level headings with children fold: collapsed by default to keep the
// list compact, expanding (and jumping) when the section title is clicked.
const collapsible = isRoot && heading.subheadings.length > 0;

// Childless top-level rows reserve the same caret-width gutter (caret 0.75rem
// + gap 0.375rem) so every top-level label aligns on one edge — otherwise a
// section with a caret reads as a child of the caret-less row above it.
const rootGutterClass = isRoot && !collapsible ? "pl-[1.125rem]" : "";
---

{
  collapsible ? (
    <li>
      <details class="toc-section">
        <summary class="flex cursor-pointer items-center gap-1.5">
          <svg
            class="toc-caret size-3 shrink-0 text-black/40 dark:text-white/40"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <polyline points="9 6 15 12 9 18" />
          </svg>
          <a href={"#" + heading.slug} class:list={linkClass}>
            {heading.text}
          </a>
        </summary>
        <ul class="ml-4 mt-0.5 space-y-0.5">
          {heading.subheadings.map((subheading: Heading) => (
            <Astro.self heading={subheading} />
          ))}
        </ul>
      </details>
    </li>
  ) : (
    <li>
      <a href={"#" + heading.slug} class:list={[...linkClass, rootGutterClass]}>
        {heading.text}
      </a>
      {heading.subheadings.length > 0 && (
        <ul class="ml-4 space-y-0.5">
          {heading.subheadings.map((subheading: Heading) => (
            <Astro.self heading={subheading} />
          ))}
        </ul>
      )}
    </li>
  )
}

<style>
  .toc-section > summary {
    list-style: none;
  }
  .toc-section > summary::-webkit-details-marker {
    display: none;
  }
  .toc-caret {
    transition: transform 0.2s ease;
  }
  .toc-section[open] > summary .toc-caret {
    transform: rotate(90deg);
  }
  @media (prefers-reduced-motion: reduce) {
    .toc-caret {
      transition: none;
    }
  }
</style>
