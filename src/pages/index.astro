---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import { SITE, HOME, SOCIALS } from "@consts";
import PostListItem from "@components/PostListItem.astro";
import Link from "@components/Link.astro";
import EntranceEpigraph from "@components/EntranceEpigraph.astro";
import { getCollection } from "astro:content";

const blog = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_POSTS_ON_HOMEPAGE);
---

<Layout title="" description={HOME.DESCRIPTION}>
  <!-- Once-per-session entrance: the Keats epigraph plays as a full-screen
       ink-reveal splash (EntranceEpigraph), so it no longer sits statically at
       the top of the page. -->
  <EntranceEpigraph />
  <Container>
    <aside data-pagefind-ignore class="mx-auto max-w-4xl text-center">
      <h1 class="sr-only">喫茶去</h1>

      <div class="space-y-20">
        <section class="animate space-y-10">
          <h2 class="font-semibold text-black dark:text-white">近期文章</h2>
          <ul class="not-prose space-y-14">
            {
              blog.map((post) => (
                <li>
                  <PostListItem entry={post} centered />
                </li>
              ))
            }
          </ul>
          <div>
            <Link href="/blog">查看全部 →</Link>
          </div>
        </section>

        <section class="animate space-y-4">
          <h2 class="font-semibold text-black dark:text-white">联系</h2>
          <ul class="not-prose flex flex-wrap justify-center gap-2">
            {
              SOCIALS.map((SOCIAL) => (
                <li class="flex gap-x-2 text-nowrap">
                  <Link
                    href={SOCIAL.HREF}
                    external
                    aria-label={`${SITE.TITLE} on ${SOCIAL.NAME}`}
                  >
                    {SOCIAL.NAME}
                  </Link>
                  {"/"}
                </li>
              ))
            }
            <li class="line-clamp-1">
              <Link
                href={`mailto:${SITE.EMAIL}`}
                aria-label={`Email ${SITE.TITLE}`}
              >
                {SITE.EMAIL}
              </Link>
            </li>
          </ul>
        </section>
      </div>
    </aside>
  </Container>
</Layout>
