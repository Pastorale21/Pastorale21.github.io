---
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import { SITE, HOME, SOCIALS } from "@consts";
import PostListItem from "@components/PostListItem.astro";
import Link from "@components/Link.astro";
import { getCollection } from "astro:content";

const blog = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, SITE.NUM_POSTS_ON_HOMEPAGE);
---

<Layout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <aside data-pagefind-ignore class="mx-auto max-w-2xl text-center">
      <div class="space-y-20">
        <header class="space-y-4">
          <h1 class="text-3xl font-semibold text-black sm:text-4xl dark:text-white">
            喫茶去
          </h1>
          <p class="leading-relaxed text-black/70 dark:text-white/70">
            「喫茶去」是赵州和尚的三字公案。此处存放读书、佛学、日本史与音乐的随记。
          </p>
        </header>

        <section class="animate space-y-10">
          <h2 class="font-semibold text-black dark:text-white">近期文章</h2>
          <ul class="not-prose space-y-16">
            {
              blog.map((post) => (
                <li>
                  <PostListItem entry={post} centered />
                </li>
              ))
            }
          </ul>
          <div>
            <Link href="/blog">查看全部 →</Link>
          </div>
        </section>

        <section class="animate space-y-4">
          <h2 class="font-semibold text-black dark:text-white">联系</h2>
          <ul class="not-prose flex flex-wrap justify-center gap-2">
            {
              SOCIALS.map((SOCIAL) => (
                <li class="flex gap-x-2 text-nowrap">
                  <Link
                    href={SOCIAL.HREF}
                    external
                    aria-label={`${SITE.TITLE} on ${SOCIAL.NAME}`}
                  >
                    {SOCIAL.NAME}
                  </Link>
                  {"/"}
                </li>
              ))
            }
            <li class="line-clamp-1">
              <Link
                href={`mailto:${SITE.EMAIL}`}
                aria-label={`Email ${SITE.TITLE}`}
              >
                {SITE.EMAIL}
              </Link>
            </li>
          </ul>
        </section>
      </div>
    </aside>
  </Container>
</Layout>
