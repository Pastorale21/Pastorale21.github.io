---
import { getCollection } from "astro:content";
import Layout from "@layouts/Layout.astro";
import Container from "@components/Container.astro";
import FormattedDate from "@components/FormattedDate.astro";
import { BLOG } from "@consts";

const data = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Fogdog-style archive: group by month (newest first). Each month is a
// borderless block — heading + title/date entries, no excerpt, no cover —
// that flows through CSS columns without ever splitting mid-month.
type Group = { key: string; label: string; posts: typeof data };

const groups = data.reduce<Group[]>((acc, post) => {
  const d = post.data.date;
  const key = `${d.getFullYear()}-${d.getMonth()}`;
  let group = acc.find((g) => g.key === key);
  if (!group) {
    group = { key, label: `${d.getFullYear()}年${d.getMonth() + 1}月`, posts: [] };
    acc.push(group);
  }
  group.posts.push(post);
  return acc;
}, []);
---

<Layout title={BLOG.TITLE} description={BLOG.DESCRIPTION}>
  <Container>
    <div data-pagefind-ignore>
      <div class="columns-1 gap-x-12 sm:columns-2">
        {
          groups.map((group) => (
            <section class="animate mb-14 break-inside-avoid">
              <h2 class="text-2xl text-black dark:text-white">{group.label}</h2>
              <ul class="not-prose mt-6 space-y-8">
                {group.posts.map((post) => (
                  <li>
                    <a href={`/${post.collection}/${post.id}`} class="group block">
                      <h3 class="text-balance text-lg leading-snug text-black transition-colors duration-300 ease-in-out group-hover:text-[var(--accent)] group-focus-visible:text-[var(--accent)] dark:text-white">
                        {post.data.title}
                      </h3>
                      <div class="mt-1 text-sm text-black/75 dark:text-white/60">
                        <FormattedDate date={post.data.date} />
                      </div>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          ))
        }
      </div>
    </div>
  </Container>
</Layout>
