---
import Head from "@components/Head.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";

type Props = {
  title: string;
  description: string;
};

const { title, description } = Astro.props;

// Brand-only tab on the home page (empty title); "Page · Brand" everywhere else.
const docTitle = title ? `${title} · Pastorale's Blog` : "Pastorale's Blog";
---

<!doctype html>
<html lang="zh-Hans">
  <head>
    <Head title={docTitle} description={description} />
  </head>
  <body>
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
