---
// TeaSeal.astro — 首页「喫茶去」茶印交互。
// 点茶印 → 墨迹显影斟出一首作品（来自 tea-works.js），并通过 iTunes Search
// API（JSONP）解析出精准的 Apple Music 专辑链接，结果缓存在 localStorage。
// 解析被拦时回退到搜索链接，永不断链。无需 React。
//
// 用法：在首页（如 src/pages/index.astro）放 <TeaSeal />，
// 通常放在 <近期文章> 列表上方。字体/颜色用站点已有的 CSS 变量，
// 缺失时有回退色。
import { works } from './tea-works.js';
---
<section class="tea">
  <div class="tea-seal" id="tea-seal" role="button" tabindex="0" aria-label="喫茶——斟一首作品">茶</div>
  <div class="tea-invite" id="tea-invite">點一下，斟一首</div>
  <div class="tea-cup"><div class="tea-work" id="tea-work" aria-live="polite"></div></div>
  <button class="tea-again" id="tea-again" type="button">再斟一首 ↻</button>
</section>

<style>
  .tea { text-align: center; padding: 1rem 0 2.4rem; }
  .tea-seal {
    width: 3.4rem; height: 3.4rem; border-radius: 999px; margin: 0 auto;
    display: grid; place-items: center; cursor: pointer; position: relative;
    border: 1.5px solid var(--accent, #b1462f); color: var(--accent, #b1462f);
    font-family: var(--font-display, Georgia, serif); font-size: 1.5rem; background: transparent;
    transition: background .35s ease, transform .25s cubic-bezier(.2,.7,.3,1.4); user-select: none; outline: none;
  }
  .tea-seal:hover { background: color-mix(in oklab, var(--accent, #b1462f) 8%, transparent); }
  .tea-seal:active { transform: scale(.92); }
  .tea-seal:focus-visible { box-shadow: 0 0 0 3px color-mix(in oklab, var(--accent, #b1462f) 22%, transparent); }
  .tea-seal::after { content: ""; position: absolute; inset: -6px; border-radius: 999px; border: 1px solid var(--accent, #b1462f); opacity: 0; transform: scale(.8); pointer-events: none; }
  .tea-seal.is-pour::after { animation: teaRipple .7s ease-out; }
  @keyframes teaRipple { 0% { opacity:.5; transform:scale(.85);} 100% { opacity:0; transform:scale(1.5);} }

  .tea-invite { margin-top: 1.05rem; font-size: .75rem; letter-spacing: .14em; color: var(--text-quiet, #6b6a64); }
  .tea-cup { min-height: 9rem; margin-top: 1.6rem; display: grid; place-items: center; }
  .tea-composer { font-size: .75rem; letter-spacing: .16em; text-transform: uppercase; color: var(--text-quiet, #6b6a64); }
  .tea-title { font-size: 1.55rem; line-height: 1.4; color: var(--text-strong, #353534); margin: .55rem auto .15rem; max-width: 28rem; text-wrap: balance; font-family: var(--font-serif, Georgia, serif); }
  .tea-op { font-family: var(--font-charter, "IM Fell English", Georgia, serif); font-style: italic; color: var(--text-muted, #555); }
  .tea-perf { font-size: .875rem; color: var(--text-muted, #555); font-style: italic; font-family: var(--font-charter, "IM Fell English", Georgia, serif); }
  .tea-listen { display: inline-flex; align-items: center; gap: .3rem; margin-top: 1.1rem; font-size: .875rem; color: var(--accent, #b1462f); text-decoration: none; border-bottom: 1px solid transparent; padding-bottom: 1px; transition: border-color .2s ease; }
  .tea-listen:hover { border-bottom-color: var(--accent, #b1462f); }
  .tea-genre { margin-top: .8rem; font-size: .75rem; letter-spacing: .18em; color: var(--text-quiet, #6b6a64); opacity: .7; }

  .tea-again { margin-top: 1.3rem; font-size: .875rem; color: var(--text-quiet, #6b6a64); background: none; border: none; cursor: pointer; font-family: var(--font-serif, Georgia, serif); letter-spacing: .04em; opacity: 0; transition: opacity .5s ease, color .2s ease; }
  .tea-again.is-show { opacity: .85; }
  .tea-again:hover { color: var(--accent, #b1462f); }

  .tea-ink-in { animation: teaInkIn .9s cubic-bezier(.2,.6,.3,1) forwards; }
  .tea-ink-out { animation: teaInkOut .42s ease forwards; }
  @keyframes teaInkIn { from { opacity:0; transform:translateY(8px); filter:blur(6px);} to { opacity:1; transform:none; filter:blur(0);} }
  @keyframes teaInkOut { from { opacity:1; filter:blur(0);} to { opacity:0; transform:translateY(-8px); filter:blur(4px);} }
  @media (prefers-reduced-motion: reduce) {
    .tea-ink-in, .tea-ink-out, .tea-seal.is-pour::after { animation: none !important; }
    .tea-ink-out { opacity: 1; }
  }
</style>

<script define:vars={{ works }}>
  (function () {
    var seal = document.getElementById('tea-seal');
    var invite = document.getElementById('tea-invite');
    var workEl = document.getElementById('tea-work');
    var again = document.getElementById('tea-again');
    if (!seal) return;

    var STORE = 'kissako_am_urls';
    var cache = {};
    try { cache = JSON.parse(localStorage.getItem(STORE) || '{}'); } catch (e) {}
    function saveCache() { try { localStorage.setItem(STORE, JSON.stringify(cache)); } catch (e) {} }
    function keyOf(w) { return w.composer + '|' + w.title + '|' + (w.op || ''); }
    function searchUrl(w) { return 'https://music.apple.com/search?term=' + encodeURIComponent(w.composer + ' ' + w.title); }

    var last = -1, started = false;
    function pick() { var i; do { i = Math.floor(Math.random() * works.length); } while (i === last && works.length > 1); last = i; return works[i]; }

    function resolveLink(w, anchor) {
      var key = keyOf(w);
      if (cache[key]) { anchor.href = cache[key]; return; }
      var term = (w.op ? w.op : w.title) + ' ' + w.composer;
      var cb = 'itunesCb_' + Math.random().toString(36).slice(2);
      var s = document.createElement('script');
      var done = function () { try { delete window[cb]; } catch (e) {} if (s.parentNode) s.parentNode.removeChild(s); };
      window[cb] = function (data) {
        try {
          var r = data && data.results && data.results[0];
          var u = r && (r.collectionViewUrl || r.trackViewUrl);
          if (u) { cache[key] = u; saveCache(); if (anchor.dataset.k === key) anchor.href = u; }
        } catch (e) {}
        done();
      };
      s.onerror = done;
      s.src = 'https://itunes.apple.com/search?limit=1&entity=album&term=' + encodeURIComponent(term) + '&callback=' + cb;
      document.head.appendChild(s);
    }

    function render(w) {
      var key = keyOf(w);
      var href = cache[key] || searchUrl(w);
      workEl.innerHTML =
        '<div class="tea-composer"></div>' +
        '<div class="tea-title"></div>' +
        '<div class="tea-perf"></div>' +
        '<a class="tea-listen" target="_blank" rel="noopener noreferrer">在 Apple Music 听 ↗</a>' +
        '<div class="tea-genre"></div>';
      workEl.querySelector('.tea-composer').textContent = w.composer;
      var t = workEl.querySelector('.tea-title');
      t.textContent = w.title;
      if (w.op) { var sp = document.createElement('span'); sp.className = 'tea-op'; sp.textContent = ' ' + w.op; t.appendChild(sp); }
      workEl.querySelector('.tea-perf').textContent = w.perf;
      var a = workEl.querySelector('.tea-listen'); a.href = href; a.dataset.k = key;
      var g = workEl.querySelector('.tea-genre'); if (w.genre) g.textContent = w.genre; else g.remove();
      if (!cache[key]) resolveLink(w, a);
      workEl.classList.remove('tea-ink-out'); void workEl.offsetWidth; workEl.classList.add('tea-ink-in');
    }

    function pour() {
      seal.classList.remove('is-pour'); void seal.offsetWidth; seal.classList.add('is-pour');
      if (!started) {
        started = true; invite.style.opacity = '0';
        setTimeout(function () { invite.style.display = 'none'; }, 400);
        render(pick());
        setTimeout(function () { again.classList.add('is-show'); }, 700);
      } else {
        workEl.classList.remove('tea-ink-in'); workEl.classList.add('tea-ink-out');
        setTimeout(function () { render(pick()); }, 420);
      }
    }
    seal.addEventListener('click', pour);
    seal.addEventListener('keydown', function (e) { if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); pour(); } });
    again.addEventListener('click', pour);
  })();
</script>
